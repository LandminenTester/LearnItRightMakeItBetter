// Prisma-Schema — deklarative Quelle des Datenmodells.
// Verbindliche Referenz je Modul: docs/database/schemas/ · Konventionen: docs/database/01.
// Migrations-Workflow: docs/database/05-prisma-and-migrations.md (MIG-1…MIG-4).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

