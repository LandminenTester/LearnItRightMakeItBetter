# Lokale Entwicklung — Werte passend zum Dev-Stack (compose.dev.yml).
# Kopieren nach apps/backend/.env (oder Repo-Root .env, je nach Startweise).
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3001

DATABASE_URL=postgresql://lir:lir@localhost:5432/lir_dev
REDIS_URL=redis://localhost:6379
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key-nicht-fuer-produktion

STORAGE_DRIVER=filesystem
STORAGE_FS_PATH=./data/media

# Dev-Secrets — NIEMALS in Produktion verwenden
APP_ENCRYPTION_KEY=ZGV2LW9ubHkta2V5LW5vdC1mb3ItcHJvZHVjdGlvbi0hIQ==
SESSION_SECRET=dev-only-session-secret-not-for-production
AUTH_PEPPER=dev-only-pepper-not-for-production

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=none
SMTP_FROM_ADDRESS=dev@localhost
SMTP_FROM_NAME=LIR Dev
