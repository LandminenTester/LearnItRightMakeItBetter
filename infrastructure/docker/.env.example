# Produktion Single-Node — Vorlage. Kopieren nach .env (chmod 600), Werte setzen.
# Vollständiger Katalog + Erklärungen: docs/deployment/04-configuration-reference.md
# Härtung: docs/security/checklists/deployment-hardening.md

# ── Release ──────────────────────────────────────────────────────────────────
LIR_VERSION=0.1.0
LIR_DOMAIN=wissen.example.org
# LIR_BACKEND_IMAGE=ghcr.io/<org>/lir-backend
# LIR_FRONTEND_IMAGE=ghcr.io/<org>/lir-frontend

# ── Kern ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://wissen.example.org
PORT=3001

# ── Secrets (je 32+ Byte Zufall, z. B. `openssl rand -base64 32`) ────────────
APP_ENCRYPTION_KEY=CHANGE_ME_base64_32_bytes
SESSION_SECRET=CHANGE_ME_base64_32_bytes
AUTH_PEPPER=CHANGE_ME_base64_32_bytes

# ── Datenbank & Redis ────────────────────────────────────────────────────────
POSTGRES_USER=lir
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lir
DATABASE_URL=postgresql://lir:CHANGE_ME@postgres:5432/lir
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ── Suche ────────────────────────────────────────────────────────────────────
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME

# ── Storage (docs/deployment/04 — filesystem | s3 | azure-blob | gcs) ────────
STORAGE_DRIVER=s3
STORAGE_S3_ENDPOINT=https://s3.example.org
STORAGE_S3_REGION=eu-central
STORAGE_S3_BUCKET=lir-media
STORAGE_S3_ACCESS_KEY=CHANGE_ME
STORAGE_S3_SECRET_KEY=CHANGE_ME
# STORAGE_S3_FORCE_PATH_STYLE=true   # für MinIO

# ── SMTP (alternativ vollständig über die Admin-UI konfigurierbar) ───────────
# SMTP_HOST=mail.example.org
# SMTP_PORT=587
# SMTP_SECURE=starttls
# SMTP_USER=noreply@example.org
# SMTP_PASSWORD=CHANGE_ME
# SMTP_FROM_ADDRESS=noreply@example.org
# SMTP_FROM_NAME=Learn it right
