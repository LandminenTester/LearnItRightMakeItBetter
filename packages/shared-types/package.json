{
  "name": "@lir/shared-types",
  "version": "0.1.0",
  "private": true,
  "description": "Zod-Schemas, Enums, Error-Codes und Permission-Katalog — eine Quelle für Backend und Frontend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
